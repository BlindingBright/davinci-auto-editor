{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DaVinci Auto-Editor AI",
  "version": "1.0.0",
  "identifier": "com.zoest.davinciautoeditor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DaVinci Auto-Editor AI",
        "width": 1100,
        "height": 820,
        "minWidth": 900,
        "minHeight": 680,
        "center": true,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "resources": ["../python/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
